{
  "name": "geoview-core",
  "version": "2.2.0",
  "description": "Lightweight viewer based on Open Layers and React for the Canadian Geospatial Platform",
  "private": true,
  "main": "src/app.tsx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Canadian-Geospatial-Platform/geoview"
  },
  "scripts": {
    "serve": "webpack serve --progress --color --config webpack.dev.js",
    "build": "npm run format && npm run fix && npm run doc && webpack --progress --color --config webpack.prod.js && npm run generate.d.ts",
    "build-dev": "webpack --progress --color --config webpack.dev-build.js",
    "doc": "typedoc src/app.tsx --logLevel Error --out public/typeDocAPI --includeVersion --entryPointStrategy expand",
    "deploy": "gh-pages -d dist -verbose",
    "format": "npm run format --prefix ../",
    "lint": "npm run lint --prefix ../",
    "fix": "npm run fix --prefix ../",
    "generate.d.ts": "tsc --noEmit false --skipLibCheck true --declaration --allowJs --emitDeclarationOnly --outDir types"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@html2canvas/html2canvas": "^1.6.3",
    "@mui/icons-material": "^7.3.2",
    "@mui/lab": "7.0.0-beta.17",
    "@mui/material": "^7.3.2",
    "@mui/system": "^6.1.3",
    "@mui/x-date-pickers": "^7.20.0",
    "@mui/x-tree-view": "^7.17.0",
    "@nieuwlandgeo/sldreader": "^0.4.3",
    "@react-pdf/renderer": "^4.5.1",
    "@react-spring/web": "^10.0.3",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "buffer": "^6.0.3",
    "comlink": "4.4.2",
    "dayjs": "^1.11.20",
    "export-to-csv": "^1.4.0",
    "geotiff": "^3.0.5",
    "html-react-parser": "^5.1.18",
    "i18next": "^26.0.8",
    "linkify-html": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "markdown-to-jsx": "~7.5.0",
    "material-react-table": "^3.2.1",
    "ol": "10.9.0",
    "ol-mapbox-style": "^12.3.5",
    "ol-stac": "^1.4.0",
    "proj4": "^2.20.8",
    "query-string": "^9.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^17.0.6",
    "sanitize-html": "^2.17.3",
    "shpjs": "^6.2.0",
    "sql.js": "^1.14.1",
    "yet-another-react-lightbox": "^3.31.0",
    "zustand": "~5.0.12"
  },
  "devDependencies": {
    "@swc/core": "^1.15.32",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@types/create-react-class": "^15.6.9",
    "@types/flux": "^3.1.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/shpjs": "^3.4.7",
    "@types/sql.js": "^1.4.11",
    "compression-webpack-plugin": "^12.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "gh-pages": "^6.3.0",
    "glob": "^13.0.6",
    "html-loader": "~5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "markdown-loader": "~8.0.0",
    "simple-zustand-devtools": "^1.1.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-bundle-size-analyzer": "^3.1.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "worker-loader": "^3.0.8"
  },
  "overrides": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@mui/lab": {
      "@mui/material": "$@mui/material"
    }
  }
}
